{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agcp.example/spec/0.9.0/schemas/constraint_evaluation.json",
  "title": "ConstraintEvaluation",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "constraint_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "type": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "outcome": {
      "$ref": "common.json#/$defs/constraint_outcome_enum"
    },
    "reason": {
      "type": "string",
      "maxLength": 2048
    }
  },
  "required": [
    "constraint_id",
    "type",
    "outcome"
  ]
}

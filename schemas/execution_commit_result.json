{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agcp.example/spec/0.9.0/schemas/execution_commit_result.json",
  "title": "ExecutionCommitResult",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.9.0"
    },
    "tenant_id": {
      "$ref": "common.json#/$defs/tenant_id"
    },
    "action_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128
    },
    "status": {
      "type": "string",
      "enum": [
        "COMMITTED",
        "REJECTED"
      ]
    },
    "rejection_code": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 128
    },
    "ledger_entry_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    }
  },
  "required": [
    "schema_version",
    "tenant_id",
    "action_id",
    "status"
  ]
}

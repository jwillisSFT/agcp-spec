{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agcp.example/spec/0.9.0/schemas/policy_module.json",
  "title": "PolicyModule",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.9.0"
    },
    "tenant_id": {
      "$ref": "common.json#/$defs/tenant_id"
    },
    "module_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "module_hash": {
      "$ref": "common.json#/$defs/hash_hex"
    },
    "artifact_ref": {
      "$ref": "common.json#/$defs/uri"
    },
    "integrity_signature": {
      "$ref": "common.json#/$defs/signature"
    },
    "status": {
      "type": "string",
      "enum": [
        "REGISTERED",
        "ACTIVE",
        "DEPRECATED",
        "RETIRED"
      ]
    },
    "created_at": {
      "$ref": "common.json#/$defs/timestamp_rfc3339"
    }
  },
  "required": [
    "schema_version",
    "tenant_id",
    "module_id",
    "version",
    "artifact_ref",
    "status",
    "created_at"
  ]
}

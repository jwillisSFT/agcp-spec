{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agcp.example/spec/0.9.0/schemas/constraint_artifact.json",
  "title": "ConstraintArtifact",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.9.0"
    },
    "tenant_id": {
      "$ref": "common.json#/$defs/tenant_id"
    },
    "constraint_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "type": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "status": {
      "$ref": "common.json#/$defs/artifact_status_enum"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "operation_types": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "maxItems": 128,
          "uniqueItems": true
        },
        "target_surfaces": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          },
          "maxItems": 128,
          "uniqueItems": true
        }
      }
    },
    "parameters": {
      "type": "object"
    },
    "effective_start": {
      "$ref": "common.json#/$defs/timestamp_rfc3339"
    },
    "effective_end": {
      "$ref": "common.json#/$defs/timestamp_rfc3339"
    },
    "hash": {
      "$ref": "common.json#/$defs/hash_hex"
    },
    "signature": {
      "$ref": "common.json#/$defs/signature"
    }
  },
  "required": [
    "schema_version",
    "tenant_id",
    "constraint_id",
    "version",
    "type",
    "status"
  ]
}

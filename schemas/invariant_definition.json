{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agcp.example/spec/0.9.0/schemas/invariant_definition.json",
  "title": "InvariantDefinition",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.9.0"
    },
    "tenant_id": {
      "$ref": "common.json#/$defs/tenant_id"
    },
    "invariant_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "invariant_type": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "enforcement_level": {
      "$ref": "common.json#/$defs/invariant_enforcement_enum"
    },
    "evaluation_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "evaluation_parameters": {
      "type": "object"
    },
    "rejection_code": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "status": {
      "$ref": "common.json#/$defs/artifact_status_enum"
    },
    "effective_start": {
      "$ref": "common.json#/$defs/timestamp_rfc3339"
    },
    "effective_end": {
      "$ref": "common.json#/$defs/timestamp_rfc3339"
    },
    "hash": {
      "$ref": "common.json#/$defs/hash_hex"
    },
    "signature": {
      "$ref": "common.json#/$defs/signature"
    }
  },
  "required": [
    "schema_version",
    "tenant_id",
    "invariant_id",
    "version",
    "invariant_type",
    "enforcement_level",
    "evaluation_ref",
    "rejection_code",
    "status"
  ]
}

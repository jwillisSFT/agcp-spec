{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agcp.example/spec/0.9.0/schemas/error_response.json",
  "title": "ErrorResponse",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "error": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rejection_code": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "message": {
          "type": "string",
          "maxLength": 4096
        },
        "details": {
          "type": "object"
        }
      },
      "required": [
        "rejection_code",
        "message"
      ]
    }
  },
  "required": [
    "error"
  ]
}

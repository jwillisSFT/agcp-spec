{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agcp.example/spec/0.9.0/schemas/exception_artifact.json",
  "title": "ExceptionArtifact",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.9.0"
    },
    "tenant_id": {
      "$ref": "common.json#/$defs/tenant_id"
    },
    "exception_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "status": {
      "$ref": "common.json#/$defs/artifact_status_enum"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "constraint_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "maxItems": 256,
          "uniqueItems": true
        },
        "constraint_types": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          },
          "maxItems": 256,
          "uniqueItems": true
        },
        "operation_types": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "maxItems": 128,
          "uniqueItems": true
        },
        "target_surfaces": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          },
          "maxItems": 128,
          "uniqueItems": true
        }
      }
    },
    "expiration": {
      "$ref": "common.json#/$defs/timestamp_rfc3339"
    },
    "approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "approver": {
            "$ref": "common.json#/$defs/principal"
          },
          "approved_at": {
            "$ref": "common.json#/$defs/timestamp_rfc3339"
          },
          "note": {
            "type": "string",
            "maxLength": 2048
          }
        },
        "required": [
          "approver",
          "approved_at"
        ]
      },
      "minItems": 1,
      "maxItems": 16
    },
    "hash": {
      "$ref": "common.json#/$defs/hash_hex"
    },
    "signature": {
      "$ref": "common.json#/$defs/signature"
    }
  },
  "required": [
    "schema_version",
    "tenant_id",
    "exception_id",
    "version",
    "status",
    "expiration",
    "approvals"
  ]
}

{
  "registry_name": "constraint-type-registry",
  "registry_version": "0.9.0",
  "status": "ACTIVE",
  "namespace_rules": {
    "core_prefix": "core.",
    "experimental_prefix": "x.",
    "vendor_prefix": "vendor."
  },
  "entries": [
    {
      "name": "core.require_signature",
      "status": "ACTIVE",
      "description": "Requires valid provenance signature(s) on the ActionEnvelope (typically enforced pre-PEC but may be asserted via PEC as well).",
      "parameters_schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "min_signatures": {
            "type": "integer",
            "minimum": 1,
            "maximum": 8
          }
        }
      }
    },
    {
      "name": "core.require_tenant_state_active",
      "status": "ACTIVE",
      "description": "Requires tenant state to be ACTIVE for action submission and/or execution authorization.",
      "parameters_schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {}
      }
    },
    {
      "name": "core.require_role",
      "status": "ACTIVE",
      "description": "Requires producer to possess at least one required role.",
      "parameters_schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "any_of_roles": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            },
            "minItems": 1,
            "maxItems": 64,
            "uniqueItems": true
          }
        },
        "required": [
          "any_of_roles"
        ]
      }
    },
    {
      "name": "core.deny_operation_type",
      "status": "ACTIVE",
      "description": "Denies specified operation_type values.",
      "parameters_schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "operation_types": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            },
            "minItems": 1,
            "maxItems": 256,
            "uniqueItems": true
          }
        },
        "required": [
          "operation_types"
        ]
      }
    },
    {
      "name": "core.deny_target_surface",
      "status": "ACTIVE",
      "description": "Denies specified target_surface values or patterns.",
      "parameters_schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "target_surfaces": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256
            },
            "minItems": 1,
            "maxItems": 256,
            "uniqueItems": true
          }
        },
        "required": [
          "target_surfaces"
        ]
      }
    },
    {
      "name": "core.require_evidence_refs",
      "status": "ACTIVE",
      "description": "Requires evidence_refs to be present (count and/or types are implementation-defined by policy).",
      "parameters_schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "min_evidence_refs": {
            "type": "integer",
            "minimum": 1,
            "maximum": 256
          }
        }
      }
    },
    {
      "name": "core.require_hitl_for_risk_label",
      "status": "ACTIVE",
      "description": "Requests HITL based on a context label (risk marker) present on the ActionEnvelope.",
      "parameters_schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "label_key": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "label_values": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256
            },
            "minItems": 1,
            "maxItems": 64,
            "uniqueItems": true
          }
        },
        "required": [
          "label_key",
          "label_values"
        ]
      }
    }
  ]
}
